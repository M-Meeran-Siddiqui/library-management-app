<style>
  /* ✅ Gradient background with infinite animation */
  body {
    background: linear-gradient(-45deg, #d3cce3, #e9e4f0, #c2e9fb, #e0c3fc);
    background-size: 400% 400%;
    animation: gradientShift 15s ease infinite;
    font-family: 'Segoe UI', sans-serif;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ✅ Hover + transition for buttons */
  .btn {
    transition: all 0.3s ease;
    font-weight: 600;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.2);
  }

  /* ✅ Smooth fade animation for flash */
  #flash-message {
    animation: fadeSlideIn 0.7s ease-in-out;
  }

  @keyframes fadeSlideIn {
    0% { opacity: 0; transform: translateY(-15px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .table-wrapper::-webkit-scrollbar {
    display: none;
  }

  .table-wrapper {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .table thead th {
    position: sticky;
    top: 0;
    background-color: #212529;
    color: white;
    z-index: 2;
  }

  .table td, .table th {
    vertical-align: middle;
    text-align: center;
  }

  .action-btn {
    width: 40px;
    height: 35px;
    padding: 6px 0;
  }
</style>

<div class="container mt-5">
  <h1 class="text-center mb-4">📚 All Books</h1>

  <div class="text-center mb-3">
    <%= link_to '➕ Add New Book', new_book_path, class: "btn btn-outline-success" %>
  </div>

  <%# ✅ Flash message with auto-hide after 3 seconds %>
  <% if notice %>
    <div id="flash-message" class="alert alert-success text-center mx-auto mb-3" style="max-width: 500px;">
      <%= notice %>
    </div>

    <script>
      setTimeout(() => {
        const flash = document.getElementById('flash-message');
        if (flash) {
          flash.style.transition = 'opacity 0.5s ease';
          flash.style.opacity = '0';
          setTimeout(() => flash.style.display = 'none', 500);
        }
      }, 3000);
    </script>
  <% end %>

  <div class="table-wrapper mx-auto shadow rounded mb-5" style="max-height: 420px; overflow-y: auto; position: relative;">
    <table class="table table-bordered table-striped table-hover mb-0">
      <thead class="table-dark">
        <tr>
          <th>Title</th>
          <th>Author</th>
          <th>ISBN</th>
          <th>Published Date</th>
          <th>Genre</th>
          <th>Available</th>
          <th colspan="3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @books.each do |book| %>
          <tr>
            <td><%= book.title %></td>
            <td><%= book.author %></td>
            <td><%= book.isbn %></td>
            <td><%= book.published_date.strftime("%d-%b-%Y") %></td>
            <td><%= book.genre %></td>
            <td>
              <% if book.available %>
                <span class="badge bg-success">Yes</span>
              <% else %>
                <span class="badge bg-danger">No</span>
              <% end %>
            </td>
            <td>
              <%= link_to book_path(book), class: "btn btn-outline-primary btn-sm action-btn", title: "View" do %>
                <i class="fas fa-eye"></i>
              <% end %>
            </td>
            <td>
              <%= link_to edit_book_path(book), class: "btn btn-outline-secondary btn-sm action-btn", title: "Edit" do %>
                <i class="fas fa-edit"></i>
              <% end %>
            </td>
            <td>
              <%= button_to book_path(book), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm action-btn", title: "Delete" do %>
                <i class="fas fa-trash-alt"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
